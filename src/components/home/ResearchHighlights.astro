---
// import vimeoThumbnail from '../../assets/images/icons/vimeo_thumbnail.png';

const base = import.meta.env.BASE_URL;

const highlights = [
  {
    title: 'Predicting Chemical Safety',
    description: 'Combining cellular imaging, transcriptomics, and proteomics across a global network of scientists to build predictive tools that reduce animal testing and bring safer medicines to people faster.',
    icon: null,
    emoji: '\u{1F9EC}',
    accent: 'var(--accent-teal)',
  },
  {
    title: 'Rescuing Mislocalized Proteins',
    description: 'Systematically screening thousands of approved drugs to find ones that can rescue diseases caused when critical proteins end up in the wrong place inside a cell, turning known medicines into new cures.',
    icon: null,
    emoji: '\u{1F489}',
    accent: 'var(--accent-gold)',
  },
  {
    title: 'Mapping the Chemical Universe',
    description: 'Creating the world\'s largest open library of how cells respond to over 136,000 drugs and genetic changes, giving AI the training data it needs to accelerate the discovery of new medicines for any disease.',
    icon: null,
    emoji: '\u{1F52C}',
    accent: 'var(--accent-teal)',
  },
];
---

<section class="py-28 px-4 sm:px-6 lg:px-8" style="background: var(--bg-content);">
  <div class="max-w-7xl mx-auto">
    <!-- Section header -->
    <div class="text-center mb-16">
      <span class="section-label">What We Do</span>
      <h2 class="mt-4" style="color: var(--text-heading);">Research</h2>
      <div class="section-divider mt-8 w-24 mx-auto"></div>
    </div>

    <!-- Videos: Anne's YouTube on left, Runxi's YouTube on right -->
    <div class="grid grid-cols-1 md:grid-cols-2 gap-8 mb-16">
      <!-- Anne's YouTube: Lab overview / research talk -->
      <div>
        <div class="rounded-xl overflow-hidden shadow-lg" style="background: var(--bg-card); border: 1px solid var(--border-card);">
          <iframe
            src="https://www.youtube.com/embed/KDQFUmDJ3nY?start=12"
            class="w-full"
            style="min-height: 300px;"
            frameborder="0"
            loading="lazy"
            allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture"
            allowfullscreen
            title="Anne Carpenter — Research Talk"
          ></iframe>
        </div>
        <p class="mt-3 text-base font-semibold text-center" style="color: var(--text-heading); font-family: var(--font-heading);">
          Anne Carpenter: When Biology Meets Computer Science
        </p>
      </div>

      <!-- Runxi's YouTube: Cell Painting for Rare Disease and Drug Discovery -->
      <div>
        <div class="rounded-xl overflow-hidden shadow-lg" style="background: var(--bg-card); border: 1px solid var(--border-card);">
          <iframe
            src="https://www.youtube.com/embed/wZFXWg_WfkU"
            class="w-full"
            style="min-height: 300px;"
            frameborder="0"
            loading="lazy"
            allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture"
            allowfullscreen
            title="Cell Painting for Rare Disease and Drug Discovery"
          ></iframe>
        </div>
        <p class="mt-3 text-base font-semibold text-center" style="color: var(--text-heading); font-family: var(--font-heading);">
          Runxi Shen: Cell Painting for Rare Disease and Drug Discovery
        </p>
      </div>
    </div>

    <!-- Vimeo: Lab overview — commented out for now
    <a href="https://vimeo.com/514015653" target="_blank" rel="noopener noreferrer" class="rounded-xl overflow-hidden shadow-lg block group" style="background: var(--bg-card);">
      <div class="relative w-full">
        <img src={vimeoThumbnail.src} alt="Lab overview video — click to watch on Vimeo" class="w-full h-auto block" />
        <div class="absolute inset-0 flex items-center justify-center bg-black/20 group-hover:bg-black/40 transition-colors">
          <svg class="w-16 h-16 text-white opacity-80 group-hover:opacity-100 group-hover:scale-110 transition-all" fill="currentColor" viewBox="0 0 24 24">
            <path d="M8 5v14l11-7z" />
          </svg>
        </div>
      </div>
    </a>
    -->

    <!-- Research Area Cards -->
    <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
      {highlights.map((item, i) => (
        <div class="card-base group relative overflow-hidden p-9" style={`animation-delay: ${i * 0.15}s`}>
          <!-- Top accent line -->
          <div class="absolute top-0 left-0 right-0 h-1 rounded-t-xl" style={`background: ${item.accent};`}></div>

          {item.icon ? (
            <img src={item.icon} alt={item.title} class="w-14 h-14 mb-6 rounded-lg object-contain" />
          ) : (
            <div class="text-5xl mb-6">{item.emoji}</div>
          )}
          <h3 class="text-2xl font-semibold mb-4" style="color: var(--text-heading);">
            {item.title}
          </h3>
          <p class="text-base leading-relaxed mb-6" style="color: var(--text-secondary);">
            {item.description}
          </p>

          <!-- Learn more link -->
          <a href={`${base}/research/`}
             class="inline-flex items-center gap-2 text-base font-semibold transition-colors"
             style={`color: ${item.accent};`}>
            Learn more
            <svg class="w-4 h-4 transition-transform group-hover:translate-x-1" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3" />
            </svg>
          </a>
        </div>
      ))}
    </div>
  </div>
</section>
