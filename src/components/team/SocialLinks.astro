---
// Renders a centered row of social/profile icon links for a team member.
// Only the links that are provided are rendered; if none are present the
// component outputs nothing (no empty divider).
//
// Icons are inline SVG using `currentColor` so they inherit color and the
// hover transition defined below. LinkedIn / GitHub / X use the standard
// brand glyphs; CV is a custom document/resume mark to stay visually
// consistent with the others.

import { SOCIAL_LINKS, type SocialLinkSet } from '../../lib/social';
export type { SocialLinkSet };

interface Props {
  links?: SocialLinkSet;
}

const { links = {} } = Astro.props;

// Render order comes from the shared SOCIAL_LINKS source of truth.
const present = SOCIAL_LINKS.filter(({ key }) => links[key]);
---

{present.length > 0 && (
  <div class="social-links mt-auto pt-7 flex items-center justify-center gap-5">
    {present.map(({ key, label }) => (
      <a
        href={links[key]}
        target="_blank"
        rel="noopener noreferrer"
        aria-label={`${label} profile`}
        title={label}
        class="social-link"
      >
        {key === 'linkedin' && (
          <svg viewBox="0 0 24 24" width="20" height="20" fill="currentColor" aria-hidden="true">
            <path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433c-1.144 0-2.063-.926-2.063-2.065 0-1.138.92-2.063 2.063-2.063 1.14 0 2.064.925 2.064 2.063 0 1.139-.925 2.065-2.064 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.225 0z" />
          </svg>
        )}
        {key === 'github' && (
          <svg viewBox="0 0 24 24" width="20" height="20" fill="currentColor" aria-hidden="true">
            <path d="M12 .297c-6.63 0-12 5.373-12 12 0 5.303 3.438 9.8 8.205 11.385.6.113.82-.258.82-.577 0-.285-.01-1.04-.015-2.04-3.338.724-4.042-1.61-4.042-1.61C4.422 18.07 3.633 17.7 3.633 17.7c-1.087-.744.084-.729.084-.729 1.205.084 1.838 1.236 1.838 1.236 1.07 1.835 2.809 1.305 3.495.998.108-.776.417-1.305.76-1.605-2.665-.3-5.466-1.332-5.466-5.93 0-1.31.465-2.38 1.235-3.22-.135-.303-.54-1.523.105-3.176 0 0 1.005-.322 3.3 1.23.96-.267 1.98-.399 3-.405 1.02.006 2.04.138 3 .405 2.28-1.552 3.285-1.23 3.285-1.23.645 1.653.24 2.873.12 3.176.765.84 1.23 1.91 1.23 3.22 0 4.61-2.805 5.625-5.475 5.92.42.36.81 1.096.81 2.22 0 1.606-.015 2.896-.015 3.286 0 .315.21.69.825.57C20.565 22.092 24 17.592 24 12.297c0-6.627-5.373-12-12-12" />
          </svg>
        )}
        {key === 'x' && (
          <svg viewBox="0 0 24 24" width="18" height="18" fill="currentColor" aria-hidden="true">
            <path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z" />
          </svg>
        )}
        {key === 'cv' && (
          <svg viewBox="0 0 24 24" width="20" height="20" fill="currentColor" fill-rule="evenodd" clip-rule="evenodd" aria-hidden="true">
            <path d="M5 2.75A1.75 1.75 0 0 1 6.75 1h7.69c.46 0 .91.18 1.23.51l3.81 3.81c.33.33.52.78.52 1.24V21.25A1.75 1.75 0 0 1 18.25 23H6.75A1.75 1.75 0 0 1 5 21.25V2.75ZM14 2.6V6c0 .55.45 1 1 1h3.4L14 2.6ZM8 11.25c0-.41.34-.75.75-.75h6.5a.75.75 0 0 1 0 1.5h-6.5A.75.75 0 0 1 8 11.25Zm0 3.5c0-.41.34-.75.75-.75h6.5a.75.75 0 0 1 0 1.5h-6.5a.75.75 0 0 1-.75-.75Zm0 3.5c0-.41.34-.75.75-.75h3.5a.75.75 0 0 1 0 1.5h-3.5a.75.75 0 0 1-.75-.75Z" />
          </svg>
        )}
      </a>
    ))}
  </div>
)}

<style>
  .social-links {
    border-top: 1px solid color-mix(in srgb, var(--text-secondary) 14%, transparent);
    /* Nudge the row toward the card's bottom edge without crowding it. */
    margin-bottom: -0.5rem;
  }
  .social-link {
    color: var(--text-secondary);
    display: inline-flex;
    transition: color 0.2s ease, transform 0.2s ease;
  }
  .social-link:hover {
    color: var(--purdue-aged);
    transform: translateY(4px);
  }
</style>
