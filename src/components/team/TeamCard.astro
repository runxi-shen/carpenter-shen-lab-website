---
import SocialLinks from './SocialLinks.astro';
import type { TeamCardMember } from '../../lib/team';

interface Props {
  member: TeamCardMember;
  // 'lead' = larger PI cards; 'member' = smaller cards for everyone else.
  variant?: 'lead' | 'member';
}

const { member, variant = 'member' } = Astro.props;
const accent = 'var(--purdue-aged)';

const isLead = variant === 'lead';
const padClass = isLead ? 'p-8' : 'p-8';
const photoClass = isLead ? 'w-36 h-36' : 'w-32 h-32';
const nameClass = isLead ? 'text-2xl' : 'text-xl';
const titleSize = isLead ? '0.95rem' : '0.9rem';
---

<div class={`card-base text-center group ${padClass} flex flex-col`}>
  <div class="pb-6">
    <img
      src={member.photoSrc}
      alt={member.name}
      class={`${photoClass} rounded-full mx-auto mb-5 object-cover`}
      style={`border: 3px solid ${accent};`}
    />

    <h3 class={`${nameClass} font-semibold mb-2`} style="color: var(--text-heading);">{member.name}</h3>

    <span class="inline-block text-sm font-semibold font-mono px-4 py-1.5 rounded-full mt-1 mb-2"
          style={`background: color-mix(in srgb, ${accent} 12%, transparent); color: ${accent};`}>
      {member.roleLabel}
    </span>

    {member.title && (
      <p class="text-base font-medium font-mono mt-1 mb-4 text-center" style={`color: var(--text-secondary); font-size: ${titleSize};`}>
        {member.title}
      </p>
    )}

    <p class="text-base leading-relaxed mt-4" style="color: var(--text-secondary);">
      {member.bio}
    </p>
  </div>

  <SocialLinks links={member.links} />
</div>
