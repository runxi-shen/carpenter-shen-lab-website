---
import purdueLogo from '../../assets/images/icons/purdue-logo.svg';

const base = import.meta.env.BASE_URL;

const navLinks = [
  { label: 'Home', href: `${base}/` },
  { label: 'People', href: `${base}/people/` },
  { label: 'Papers', href: `${base}/papers/` },
  { label: 'News', href: `${base}/news/` },
  { label: 'Positions', href: `${base}/positions/` },
];
---

<header
  class="fixed top-0 left-0 right-0 z-50 backdrop-blur-md border-b"
  style="background: var(--nav-bg); border-color: var(--border-dark);"
>
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="flex items-center justify-between h-20">
      <!-- Logo / Lab Name -->
      <a href={base} class="flex items-center gap-3 group">
        <img
          src={purdueLogo.src}
          alt="Purdue University"
          class="h-8 w-auto"
          style="filter: brightness(0) invert(1); opacity: 0.9;"
        />
        <div class="hidden sm:flex items-baseline gap-2">
          <span class="font-bold text-xl" style="color: var(--accent-gold);">
            Carpenter-Shen Lab
          </span>
        </div>
      </a>

      <!-- Desktop Navigation — larger fonts -->
      <nav class="hidden lg:flex items-center gap-1">
        {navLinks.map(link => (
          <a
            href={link.href}
            class="px-4 py-2 text-lg font-semibold rounded-lg transition-colors hover:text-[var(--accent-gold)]"
            style="color: var(--nav-text);"
          >
            {link.label}
          </a>
        ))}
      </nav>

      <!-- Mobile hamburger -->
      <button
        id="mobile-menu-btn"
        class="lg:hidden p-2 rounded-lg"
        style="color: var(--nav-text);"
        aria-label="Toggle menu"
      >
        <svg class="w-7 h-7" fill="none" viewBox="0 0 24 24" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16" />
        </svg>
      </button>
    </div>
  </div>

  <!-- Mobile Navigation -->
  <div
    id="mobile-menu"
    class="lg:hidden hidden border-t"
    style="background: var(--nav-bg); border-color: var(--border-dark);"
  >
    <div class="px-4 py-3 space-y-1">
      {navLinks.map(link => (
        <a
          href={link.href}
          class="block px-3 py-2.5 text-base font-semibold rounded-lg transition-colors"
          style="color: var(--nav-text);"
        >
          {link.label}
        </a>
      ))}
    </div>
  </div>
</header>

<script>
  function initMobileMenu() {
    const btn = document.getElementById('mobile-menu-btn');
    const menu = document.getElementById('mobile-menu');
    if (btn && !btn.dataset.listenerAttached) {
      btn.dataset.listenerAttached = 'true';
      btn.addEventListener('click', () => {
        menu?.classList.toggle('hidden');
      });
    }
  }
  initMobileMenu();
  document.addEventListener('astro:after-swap', initMobileMenu);
</script>
