---
import { Image } from 'astro:assets';
import jumpLogo from '../../assets/images/icons/jump_cellpainting-343x221.png';

const base = import.meta.env.BASE_URL;

// Research problems, in priority order. Each "media" is a Purdue-branded
// colour placeholder for now; real project imagery drops in here later.
const projects = [
  {
    title: 'Rescuing Mislocalized Proteins',
    description:
      'When a critical protein ends up in the wrong place inside a cell, disease can follow. We systematically screen thousands of approved drugs to find ones that guide these proteins back to where they belong, turning medicines we already have into new cures.',
    url: 'https://vista-consortium.broadinstitute.org/',
    label: 'VISTA Consortium',
    from: 'var(--purdue-gold)',
    to: 'var(--purdue-aged)',
  },
  {
    title: 'Predicting Chemical Safety',
    description:
      'We combine cellular imaging, transcriptomics, and proteomics across a global network of scientists to build predictive tools for chemical safety, reducing reliance on animal testing and bringing safer medicines to people faster.',
    url: 'https://oasisconsortium.org/',
    label: 'OASIS Consortium',
    from: 'var(--purdue-rush)',
    to: 'var(--purdue-aged)',
  },
  {
    title: 'Mapping the Chemical Universe',
    description:
      'We are building the world’s largest open library of how cells respond to over 136,000 drugs and genetic changes, giving AI the training data it needs to accelerate the discovery of new medicines for any disease.',
    url: 'https://jump-cellpainting.broadinstitute.org/',
    label: 'JUMP-Cell Painting Consortium',
    from: 'var(--purdue-field)',
    to: 'var(--purdue-aged)',
    image: jumpLogo,
    imageAlt:
      'JUMP Cell Painting illustration: a field of stained cells with one magnified to show its organelles.',
  },
];
---

<section id="research" class="py-28 px-4 sm:px-6 lg:px-8 scroll-mt-24" style="background: var(--bg-content);">
  <div class="max-w-7xl mx-auto">
    <!-- Section header -->
    <div class="text-center mb-16">
      <span class="section-label">What We Do</span>
      <h2 class="mt-4" style="color: var(--text-heading);">Research</h2>
      <div class="section-divider mt-8 w-24 mx-auto"></div>
    </div>

    <!-- Videos: Anne's YouTube on left, Runxi's YouTube on right -->
    <div class="grid grid-cols-1 md:grid-cols-2 gap-8 mb-24">
      <!-- Anne's YouTube: Lab overview / research talk -->
      <div>
        <div class="rounded-xl overflow-hidden shadow-lg" style="background: var(--bg-card); border: 1px solid var(--border-card);">
          <iframe
            src="https://www.youtube.com/embed/KDQFUmDJ3nY?start=12"
            class="w-full"
            style="min-height: 300px;"
            frameborder="0"
            loading="lazy"
            allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture"
            allowfullscreen
            title="Anne Carpenter — Research Talk"
          ></iframe>
        </div>
        <p class="video-caption">Anne Carpenter: When Biology Meets Computer Science</p>
      </div>

      <!-- Runxi's YouTube: Cell Painting for Rare Disease and Drug Discovery -->
      <div>
        <div class="rounded-xl overflow-hidden shadow-lg" style="background: var(--bg-card); border: 1px solid var(--border-card);">
          <iframe
            src="https://www.youtube.com/embed/wZFXWg_WfkU"
            class="w-full"
            style="min-height: 300px;"
            frameborder="0"
            loading="lazy"
            allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture"
            allowfullscreen
            title="Cell Painting for Rare Disease and Drug Discovery"
          ></iframe>
        </div>
        <p class="video-caption">Runxi Shen: Cell Painting for Rare Disease and Drug Discovery</p>
      </div>
    </div>

    <!-- Problems we want to solve — alternating text / media rows -->
    <div class="text-center mb-16">
      <span class="section-label">Our Focus</span>
      <h2 class="mt-4" style="color: var(--text-heading);">Problems to solve</h2>
      <div class="section-divider mt-8 w-24 mx-auto"></div>
    </div>

    <div class="project-list">
      {projects.map((p, i) => (
        p.image ? (
          /* Feature row — two-tone band: pale zone holds the illustration,
             gold zone holds the text, magnified cell straddles the seam */
          <article class="project-row feature-row">
            <figure class="feature-image">
              <Image src={p.image} alt={p.imageAlt} widths={[343]} sizes="(max-width: 767px) 80vw, 40vw" />
            </figure>

            <div class="feature-text">
              <h3 class="project-title">{p.title}</h3>
              <p class="project-desc">{p.description}</p>
              <a href={p.url} target="_blank" rel="noopener noreferrer" class="project-link feature-link">
                {p.label}
                <svg class="project-link-arrow" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3" />
                </svg>
              </a>
            </div>
          </article>
        ) : (
          <article class={`project-row ${i % 2 === 1 ? 'is-reversed' : ''}`}>
            <!-- Media placeholder — Purdue colour block until imagery is added -->
            <div class="project-media" style={`--from: ${p.from}; --to: ${p.to};`}>
              <span class="project-media-label">Image coming soon</span>
            </div>

            <!-- Text -->
            <div class="project-text">
              <h3 class="project-title">{p.title}</h3>
              <p class="project-desc">{p.description}</p>
              <a href={p.url} target="_blank" rel="noopener noreferrer" class="project-link">
                Learn more
                <svg class="project-link-arrow" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3" />
                </svg>
              </a>
            </div>
          </article>
        )
      ))}
    </div>
  </div>
</section>

<style>
  .video-caption {
    margin-top: 0.75rem;
    text-align: center;
    font-family: var(--font-heading);
    font-weight: 600;
    font-size: 1rem;
    color: var(--text-heading);
  }

  /* ─── Project rows ─── */
  .project-list {
    display: flex;
    flex-direction: column;
    gap: 5rem;
  }
  .project-row {
    display: grid;
    grid-template-columns: 1fr 1fr;
    align-items: center;
    gap: clamp(2rem, 5vw, 4.5rem);
  }
  /* Alternate the media to the opposite side on every other row */
  .project-row.is-reversed .project-media {
    order: 2;
  }

  /* Media placeholder */
  .project-media {
    position: relative;
    aspect-ratio: 4 / 3;
    border-radius: 8px;
    overflow: hidden;
    background:
      repeating-linear-gradient(
        77deg,
        rgba(255, 255, 255, 0.06) 0,
        rgba(255, 255, 255, 0.06) 2px,
        transparent 2px,
        transparent 26px
      ),
      linear-gradient(135deg, var(--from) 0%, var(--to) 100%);
    box-shadow: 0 1px 2px rgba(26, 26, 26, 0.05), 0 14px 40px rgba(142, 111, 62, 0.12);
  }
  .project-media-label {
    position: absolute;
    bottom: 0.9rem;
    right: 1.1rem;
    font-family: var(--font-label);
    font-size: 0.8rem;
    font-weight: 600;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    color: rgba(26, 26, 26, 0.55);
  }

  /* Text block */
  .project-title {
    font-family: var(--font-display);        /* Plus Jakarta Sans, site heading font */
    font-weight: 700;
    font-size: clamp(1.5rem, 2.3vw, 2rem);
    line-height: 1.15;
    letter-spacing: -0.015em;
    color: var(--text-heading);
    margin: 0 0 1.1rem 0;
  }
  .project-desc {
    font-family: var(--font-body);           /* Plus Jakarta Sans, site body font */
    font-weight: 400;
    font-size: 1.05rem;
    line-height: 1.7;
    color: var(--text-secondary);
    text-align: justify;
    text-justify: inter-word;
    margin: 0 0 1.5rem 0;
  }
  .project-link {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    font-family: var(--font-label);
    font-weight: 600;
    font-size: 1.05rem;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    color: var(--purdue-aged);
    border-bottom: 2px solid transparent;
    padding-bottom: 2px;
    transition: color 0.18s ease, border-color 0.18s ease;
  }
  .project-link:hover {
    color: var(--purdue-rush);
    border-bottom-color: var(--purdue-rush);
  }
  .project-link-arrow {
    width: 1.05rem;
    height: 1.05rem;
    transition: transform 0.18s ease;
  }
  .project-link:hover .project-link-arrow {
    transform: translateX(4px);
  }

  /* ─── Feature row: image rectangle partially overlapping a gold panel ─── */
  .feature-row {
    position: relative;
    /* image-zone | shared overlap | text — image fills the left, its right
       edge lapping onto the gold panel that starts under the overlap track */
    grid-template-columns: 36% 6% 58%;
    gap: 0;
    align-items: center;
  }
  /* The text block IS the gold panel; the image overlaps its left edge */
  .feature-text {
    grid-row: 1;
    grid-column: 2 / 4;
    z-index: 1;
    align-self: stretch;
    display: flex;
    flex-direction: column;
    justify-content: center;
    background: linear-gradient(135deg, #F5E8C2 0%, #ECD8A2 100%);
    border: none;
    border-radius: 0;
    box-shadow: 0 12px 34px rgba(142, 111, 62, 0.10);
    /* left padding clears the overlapping illustration */
    padding: 2.5rem 3rem 2.5rem 4.5rem;
  }
  .feature-image {
    grid-row: 1;
    grid-column: 1 / 3;
    z-index: 2;
    margin: 0;
    justify-self: start;       /* flush to the band's left edge — no left gap */
  }
  .feature-image :global(img) {
    display: block;
    width: 100%;
    max-width: 520px;
    height: auto;
    filter: drop-shadow(0 14px 24px rgba(142, 111, 62, 0.20));
  }
  .feature-link {
    font-size: 1.2rem;        /* a touch larger than the standard project link */
    margin-top: 0.35rem;
  }
  .feature-link .project-link-arrow {
    width: 1.2rem;
    height: 1.2rem;
  }
  .feature-text .project-desc {
    color: #4a4334;        /* warm dark for contrast on the gold panel */
  }

  /* ─── Mobile: stack, media always on top ─── */
  @media (max-width: 767px) {
    .project-row,
    .project-row.is-reversed {
      grid-template-columns: 1fr;
      gap: 1.5rem;
    }
    .project-row.is-reversed .project-media {
      order: 0;
    }
    .project-desc {
      text-align: left;
    }

    /* Feature row collapses: illustration on top dips onto the gold panel below */
    .feature-row {
      grid-template-columns: 1fr;
      gap: 0;
    }
    .feature-image {
      grid-row: 1;
      grid-column: 1;
      justify-self: center;
      margin: 0;
      transform: translateY(1.75rem);
      z-index: 2;
    }
    .feature-image :global(img) {
      margin: 0 auto;
      max-width: 280px;
    }
    .feature-text {
      grid-row: 2;
      grid-column: 1;
      padding: 3.5rem 1.75rem 2.25rem;
      text-align: center;
    }
    .feature-text .project-desc {
      text-align: left;
    }
  }
</style>
