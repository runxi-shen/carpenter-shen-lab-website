---
const base = import.meta.env.BASE_URL;

const realNews = {
  date: '2026-04-08',
  category: 'Announcement',
  title: 'Carpenter-Shen Lab launches at Purdue University',
  excerpt: 'We are excited to announce the establishment of the Carpenter-Shen Lab at Purdue University, continuing our mission in computational image analysis for drug discovery.',
  link: 'https://www.linkedin.com/posts/annecarpenter1_im-thrilled-to-announce-im-joining-purdue-activity-7447729701122547713-PNyx',
};

function formatDate(dateStr: string): string {
  const [y, m, d] = dateStr.split('-');
  const date = new Date(+y, +m - 1, +d);
  return date.toLocaleDateString('en-US', { month: 'short', day: 'numeric', year: 'numeric' });
}
---

<section id="latest-news" class="py-28 px-4 sm:px-6 lg:px-8 scroll-mt-24" style="background: var(--bg-content);">
  <div class="max-w-7xl mx-auto">
    <!-- Section header -->
    <div class="text-center mb-16">
      <span class="section-label">Stay Updated</span>
      <h2 class="mt-4" style="color: var(--text-heading);">Latest News</h2>
      <p class="mt-4 max-w-3xl mx-auto text-lg text-center" style="color: var(--text-secondary);">
        Recent announcements, publications, and updates from our lab.
      </p>
      <div class="section-divider mt-8 w-24 mx-auto"></div>
    </div>

    <!-- News Cards -->
    <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
      <!-- Real announcement -->
      <article class="card-base flex flex-col p-8">
        <div class="flex items-center gap-3 mb-4">
          <span class="mono-label" style="font-size: 0.75rem;">{realNews.category}</span>
          <span class="text-sm font-mono" style="color: var(--text-secondary);">
            {formatDate(realNews.date)}
          </span>
        </div>
        <h3 class="text-lg font-semibold mb-3 leading-snug" style="color: var(--text-heading);">
          {realNews.title}
        </h3>
        <p class="text-base leading-relaxed flex-1" style="color: var(--text-secondary);">
          {realNews.excerpt}
        </p>
        <a href={realNews.link}
           target="_blank"
           rel="noopener noreferrer"
           class="inline-flex items-center gap-1.5 mt-5 text-base font-medium"
           style="color: var(--accent-gold);">
          Read more
          <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" />
          </svg>
        </a>
      </article>

      {/* Placeholder cards */}
      {[1, 2].map(() => (
        <article class="card-base flex flex-col items-center justify-center text-center min-h-[200px]" style="border-style: dashed;">
          <div class="w-10 h-10 rounded-full mb-3 flex items-center justify-center" style="background: var(--border-subtle);">
            <svg class="w-5 h-5" style="color: var(--text-secondary);" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M12 6v6m0 0v6m0-6h6m-6 0H6" />
            </svg>
          </div>
          <p class="text-sm font-medium text-center" style="color: var(--text-secondary);">More to come</p>
          <p class="text-xs mt-1 text-center" style="color: var(--text-secondary); opacity: 0.6;">Stay tuned for updates</p>
        </article>
      ))}
    </div>

    <!-- CTA -->
    <div class="text-center mt-12">
      <a href={`${base}/news/`}
         class="inline-flex items-center gap-2 text-sm font-medium"
         style="color: var(--accent-gold);">
        View all news
        <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3" />
        </svg>
      </a>
    </div>
  </div>
</section>
