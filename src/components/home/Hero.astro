---
const base = import.meta.env.BASE_URL;
---

<section class="hero-section relative min-h-screen flex items-center overflow-hidden"
         style="background: var(--bg-page);">

  <!-- Atmospheric radial gold wash -->
  <div class="absolute inset-0 pointer-events-none" style="background: var(--hero-wash);"></div>

  <!-- Subtle Boilermaker grain — Dust circles, very faint -->
  <div class="absolute inset-0 pointer-events-none opacity-[0.06]"
       style="background-image: radial-gradient(circle, #8E6F3E 1px, transparent 1px); background-size: 56px 56px;"></div>

  <div class="relative z-10 max-w-7xl mx-auto px-6 sm:px-8 lg:px-12 w-full py-24">

    <!-- Mission visual box — bordered cream card, fully justified -->
    <div class="hero-card animate-fade-in">
      <h1 class="hero-headline">
        Very few people get to solve puzzles all day long and <strong class="hero-accent">directly help patients</strong> suffering from disease.
      </h1>

      <p class="hero-body">
        We develop advanced methods and software to make discoveries in
        <span class="text-accent">cell images</span>.
        The rich information can reveal the causes and cures for diseases, and the impact of chemicals on biological systems.
        We work across all disease areas, from
        <span class="text-accent">cancer</span> and
        <span class="text-accent">psychiatric disease</span> to
        <span class="text-accent">rare disorders</span> and
        <span class="text-accent">infectious disease</span>.
      </p>

      <div class="hero-ctas">
        <a href={`${base}/#research`} class="cta-primary">
          Explore Research
          <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M17 8l4 4m0 0l-4 4m4-4H3" />
          </svg>
        </a>
      </div>
    </div>
  </div>

  <!-- Scroll indicator -->
  <div id="scroll-hint"
       class="absolute bottom-8 left-1/2 -translate-x-1/2 flex flex-col items-center gap-2 transition-opacity duration-500"
       style="color: var(--purdue-aged);">
    <span class="text-xs font-medium tracking-widest uppercase" style="font-family: var(--font-label);">Scroll</span>
    <svg class="w-4 h-4 animate-bounce" fill="none" viewBox="0 0 24 24" stroke="currentColor">
      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 14l-7 7m0 0l-7-7m7 7V3" />
    </svg>
  </div>
</section>

<style>
  .hero-card {
    background: rgba(255, 255, 255, 0.55);
    border: 1px solid rgba(142, 111, 62, 0.18);
    border-radius: 4px;
    padding: clamp(1.75rem, 3.5vw, 2.75rem);
    box-shadow: 0 1px 2px rgba(26, 26, 26, 0.03), 0 12px 40px rgba(142, 111, 62, 0.08);
    -webkit-backdrop-filter: blur(2px);
    backdrop-filter: blur(2px);
    max-width: 720px;
  }

  .hero-headline {
    font-family: var(--font-condensed);
    font-weight: 600;
    font-size: clamp(1.45rem, 2.6vw, 2.05rem);
    line-height: 1.25;
    letter-spacing: -0.005em;
    color: var(--text-heading);
    text-align: justify;
    text-justify: inter-word;
    margin: 0 0 1.5rem 0;
  }
  .hero-headline .hero-accent {
    font-style: normal;
    font-weight: 700;
    color: var(--purdue-aged);
  }

  .hero-body {
    font-family: var(--font-condensed);
    font-weight: 500;
    font-size: clamp(1rem, 1.2vw, 1.1rem);
    line-height: 1.6;
    color: var(--text-primary);
    text-align: justify;
    text-justify: inter-word;
    margin: 0 0 1.75rem 0;
  }

  .hero-ctas {
    display: flex;
    flex-wrap: wrap;
    gap: 0.75rem;
  }
</style>

<script>
  function initScrollHint() {
    const hint = document.getElementById('scroll-hint');
    if (!hint || hint.dataset.listenerAttached) return;
    hint.dataset.listenerAttached = 'true';

    let hidden = false;
    window.addEventListener('scroll', () => {
      if (!hidden && window.scrollY > 50) {
        hint.style.opacity = '0';
        hint.style.pointerEvents = 'none';
        hidden = true;
      }
    }, { passive: true });
  }

  initScrollHint();
  document.addEventListener('astro:after-swap', initScrollHint);
</script>
