---
import PageLayout from '../layouts/PageLayout.astro';
import TeamCard from '../components/team/TeamCard.astro';
import { getTeamGrouped } from '../lib/team';

const { leads, members } = await getTeamGrouped();
---

<PageLayout
  title="People | Carpenter-Shen Lab"
  description="Meet the researchers of the Carpenter-Shen Lab at Purdue University."
>
  <section style="background: var(--bg-content);">
    <!-- Full-viewport banner: header + PI cards land complete on first paint -->
    <div class="team-banner px-4 sm:px-6 lg:px-8">
      <div class="max-w-7xl mx-auto w-full">
        <!-- Section header — sized to match the Research section -->
        <div class="text-center mb-10">
          <span class="section-label">Who We Are</span>
          <h1 class="mt-3" style="color: var(--text-heading); font-size: clamp(1.7rem, 2.8vw, 2.5rem); font-weight: 700; letter-spacing: -0.015em;">
            Our Team
          </h1>
          <p class="mt-6 max-w-6xl mx-auto" style="color: var(--text-secondary); font-size: clamp(1.05rem, 1.25vw, 1.2rem); line-height: 1.6; text-align: justify; text-justify: inter-word;">
            Our computational lab combines expertise in computational biology, machine learning, and cell biology
            to push the boundaries of image-based drug discovery, in collaboration with biologists who create samples, images, and other omics data.
          </p>
          <div class="section-divider mt-7 w-24 mx-auto"></div>
        </div>

        <!-- PI Cards — span the same width as the member grid below -->
        <div class="grid grid-cols-1 md:grid-cols-2 gap-10 max-w-6xl mx-auto">
          {leads.map(member => <TeamCard member={member} variant="lead" />)}
        </div>
      </div>
    </div>

    <!-- Everyone else, revealed on scroll below the banner -->
    <div class="px-4 sm:px-6 lg:px-8 pt-6 pb-24">
      <div class="max-w-7xl mx-auto">
        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-10 max-w-6xl mx-auto">
          {members.map(member => <TeamCard member={member} variant="member" />)}
        </div>
      </div>
    </div>
  </section>
</PageLayout>

<style>
  /* Full-viewport banner: fills the screen below the nav (main has pt-20 =
     80px). min-height (not height) lets it grow on short windows so the PI
     cards never clip; svh stays stable across browser/fullscreen chrome. */
  .team-banner {
    min-height: calc(100svh - 80px);
    display: flex;
    flex-direction: column;
    justify-content: center;
    padding-top: 2rem;
    padding-bottom: 2rem;
  }
  @supports not (height: 100svh) {
    .team-banner { min-height: calc(100vh - 80px); }
  }
</style>
