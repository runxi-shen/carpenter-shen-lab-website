---
import purdueLogo from '../../assets/images/icons/purdue-logo.svg';

const base = import.meta.env.BASE_URL;

const navLinks = [
  { label: 'Research',    href: `${base}/#research` },
  { label: 'People',      href: `${base}/people/` },
  { label: 'Papers',      href: `${base}/papers/` },
  { label: 'Latest News', href: `${base}/news/` },
];

const joinUrl = 'https://docs.google.com/document/d/1R5kSSUX4A3x0CZYsTUdUtxPJYHRwZ04SIl5G06_MrlQ/preview?tab=t.0';
const purdueUrl = 'https://www.purdue.edu/';
---

<header
  class="fixed top-0 left-0 right-0 z-50 backdrop-blur-md border-b"
  style="background: var(--nav-bg); border-color: var(--nav-border);"
>
  <div class="max-w-7xl mx-auto px-6 sm:px-8 lg:px-12">
    <div class="flex items-center justify-between h-16">

      <!-- Brand cluster — Purdue logo links to purdue.edu; lab name links home -->
      <div class="flex items-center gap-3 sm:gap-4">
        <a
          href={purdueUrl}
          target="_blank"
          rel="noopener noreferrer"
          class="brand-logo-link"
          aria-label="Purdue University"
        >
          <img src={purdueLogo.src} alt="Purdue University" class="purdue-mark" />
        </a>
        <span class="wordmark-divider" aria-hidden="true"></span>
        <a href={base} class="wordmark-link" aria-label="Carpenter-Shen Lab — Home">
          <span class="wordmark-title">Carpenter-Shen Lab</span>
        </a>
      </div>

      <!-- Desktop Navigation — all items vertically centered -->
      <nav class="hidden lg:flex items-center gap-0">
        {navLinks.map(link => (
          <a href={link.href} class="nav-link">
            {link.label}
          </a>
        ))}

        <!-- Join the Lab — rectangular CTA, vertically centered -->
        <a
          href={joinUrl}
          target="_blank"
          rel="noopener noreferrer"
          class="join-cta"
        >
          Join the Lab
        </a>
      </nav>

      <!-- Mobile hamburger -->
      <button
        id="mobile-menu-btn"
        class="lg:hidden p-2 rounded-md self-center"
        style="color: var(--nav-text);"
        aria-label="Toggle menu"
      >
        <svg class="w-7 h-7" fill="none" viewBox="0 0 24 24" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16" />
        </svg>
      </button>
    </div>
  </div>

  <!-- Mobile Navigation -->
  <div
    id="mobile-menu"
    class="lg:hidden hidden border-t"
    style="background: var(--nav-bg); border-color: var(--nav-border);"
  >
    <div class="px-6 py-4 space-y-1">
      {navLinks.map(link => (
        <a href={link.href} class="nav-link-mobile">{link.label}</a>
      ))}
      <a href={joinUrl} target="_blank" rel="noopener noreferrer" class="join-cta-mobile">
        Join the Lab
      </a>
    </div>
  </div>
</header>

<style>
  /* ─── Wordmark ─── */
  /* The logo height (1.65rem) is the single source of truth for the brand
     cluster: the divider matches it exactly, and the lab name is sized so
     its uppercase cap height reads as visually equal to the mark. */
  .purdue-mark {
    height: 1.5rem;                      /* official horizontal PU lockup */
    width: auto;
    display: block;
    flex-shrink: 0;
  }
  .brand-logo-link {
    display: inline-flex;
    align-items: center;
    transition: opacity 0.18s ease;
  }
  .brand-logo-link:hover {
    opacity: 0.8;
  }
  .wordmark-divider {
    width: 1px;
    height: 1.5rem;
    background: var(--border-strong);
    flex-shrink: 0;
  }
  /* Lab name — clickable like the nav links, with a hover underline.
     border-bottom is reserved transparent so hovering never shifts layout. */
  .wordmark-link {
    display: inline-flex;
    align-items: center;
    border-bottom: 3px solid transparent;
    transition: border-color 0.18s ease;
  }
  .wordmark-link:hover {
    border-bottom-color: var(--purdue-rush);
  }
  .wordmark-link:hover .wordmark-title {
    color: var(--purdue-aged);
  }
  .wordmark-title {
    font-family: var(--font-label);
    font-weight: 600;                    /* lighter than before, per feedback */
    /* Sized a touch above the logo's matched cap height, with tighter
       tracking so the wordmark reads as more condensed. */
    font-size: 2rem;
    letter-spacing: -0.012em;
    color: var(--text-heading);
    text-transform: uppercase;
    line-height: 1;
    transition: color 0.18s ease;
  }

  /* ─── Desktop nav links ─── */
  .nav-link {
    display: inline-flex;
    align-items: center;
    padding: 0.4rem 0.85rem;
    font-family: var(--font-label);
    font-weight: 600;                    /* less bold, still larger */
    font-size: 1.35rem;
    letter-spacing: 0.045em;
    text-transform: uppercase;
    color: var(--text-heading);
    border-bottom: 3px solid transparent;
    transition: color 0.18s ease, border-color 0.18s ease;
  }
  .nav-link:hover {
    color: var(--purdue-aged);
    border-bottom-color: var(--purdue-rush);
  }

  /* ─── Join the Lab — rectangular CTA, full bar height ─── */
  .join-cta {
    display: inline-flex;
    align-items: center;
    height: 4rem;                        /* matches the header's h-16 top bar */
    margin-left: 1rem;
    padding: 0 1.5rem;
    font-family: var(--font-label);
    font-weight: 600;
    font-size: 1.45rem;
    letter-spacing: 0.05em;
    text-transform: uppercase;
    color: #1A1A1A;
    background: var(--purdue-rush);
    border: 0;
    border-radius: 0;
    transition: background 0.18s ease, color 0.18s ease;
  }
  .join-cta:hover {
    background: var(--purdue-field);
    color: #000;
  }

  /* ─── Mobile ─── */
  .nav-link-mobile {
    display: block;
    font-family: var(--font-label);
    font-weight: 600;
    font-size: 1.3rem;
    letter-spacing: 0.04em;
    text-transform: uppercase;
    color: var(--text-heading);
    padding: 0.85rem 0.5rem;
    border-radius: 0.5rem;
    transition: background 0.2s ease;
  }
  .nav-link-mobile:hover {
    background: rgba(207, 185, 145, 0.18);
    color: var(--purdue-aged);
  }
  .join-cta-mobile {
    display: inline-block;
    font-family: var(--font-label);
    font-weight: 600;
    font-size: 1.2rem;
    letter-spacing: 0.05em;
    text-transform: uppercase;
    color: #1A1A1A;
    background: var(--purdue-rush);
    padding: 0.85rem 1.5rem;
    border-radius: 0;
    margin-top: 0.5rem;
  }
</style>

<script>
  function initMobileMenu() {
    const btn = document.getElementById('mobile-menu-btn');
    const menu = document.getElementById('mobile-menu');
    if (btn && !btn.dataset.listenerAttached) {
      btn.dataset.listenerAttached = 'true';
      btn.addEventListener('click', () => {
        menu?.classList.toggle('hidden');
      });
    }
  }
  initMobileMenu();
  document.addEventListener('astro:after-swap', initMobileMenu);
</script>
